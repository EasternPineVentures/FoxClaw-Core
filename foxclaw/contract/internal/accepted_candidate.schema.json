{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://easternpineventures.example/foxclaw/internal/accepted_candidate.schema.json",
  "title": "FoxClaw Internal AcceptedCandidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "accepted_candidate_id",
    "raw_event_id",
    "parse_attempt_id",
    "source_ref",
    "parser_version",
    "candidate_type",
    "normalized_payload",
    "confidence",
    "admission_policy_version",
    "admission_reason",
    "evidence_hash",
    "status",
    "created_at",
    "lineage"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "internal.accepted_candidate.v1"},
    "accepted_candidate_id": {"type": "string"},
    "raw_event_id": {"type": "string"},
    "parse_attempt_id": {"type": "string"},
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_ref_id", "source_ref_type", "privacy_classification"],
      "properties": {
        "source_ref_id": {"type": "string"},
        "source_ref_type": {"type": "string"},
        "privacy_classification": {
          "type": "string",
          "enum": ["private", "public", "sanitized_fixture", "UNKNOWN_PENDING_A2_INVENTORY"]
        }
      }
    },
    "parser_version": {"type": "string"},
    "candidate_type": {"type": "string"},
    "normalized_payload": {"type": "object"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "admission_policy_version": {"type": "string"},
    "admission_reason": {"type": "string"},
    "evidence_hash": {"type": "string"},
    "status": {"type": "string", "enum": ["accepted", "superseded", "rejected"]},
    "created_at": {"type": "string", "format": "date-time"},
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["raw_event_id", "parse_attempt_id", "content_hash"],
      "properties": {
        "raw_event_id": {"type": "string"},
        "parse_attempt_id": {"type": "string"},
        "content_hash": {"type": "string"}
      }
    }
  }
}
