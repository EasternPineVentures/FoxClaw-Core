{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://easternpineventures.example/foxclaw/internal/raw_source_event.schema.json",
  "title": "FoxClaw Internal RawSourceEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "raw_event_id",
    "source_kind",
    "observed_at",
    "captured_at",
    "ingested_at",
    "private_source_ref",
    "content",
    "synthetic",
    "deduplication",
    "payload_classification",
    "publicability",
    "quarantine",
    "lineage"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "internal.raw_source_event.v1"},
    "raw_event_id": {"type": "string"},
    "source_kind": {"type": "string", "enum": ["discord", "coinfox", "news", "market", "manual"]},
    "observed_at": {"type": "string", "format": "date-time"},
    "captured_at": {"type": "string", "format": "date-time"},
    "ingested_at": {"type": "string", "format": "date-time"},
    "private_source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_ref_id", "source_ref_type", "privacy_classification"],
      "properties": {
        "source_ref_id": {"type": "string"},
        "source_ref_type": {"type": "string"},
        "privacy_classification": {
          "type": "string",
          "enum": ["private", "public", "sanitized_fixture"]
        },
        "private_location_hint": {"type": "string"}
      }
    },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content_hash", "content_excerpt", "content_mime", "sanitized"],
      "properties": {
        "content_hash": {"type": "string"},
        "content_excerpt": {"type": "string"},
        "content_mime": {"type": "string"},
        "sanitized": {"type": "boolean"}
      }
    },
    "synthetic": {"type": "boolean"},
    "deduplication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["duplicate", "duplicate_of_raw_event_id", "dedupe_key"],
      "properties": {
        "duplicate": {"type": "boolean"},
        "duplicate_of_raw_event_id": {"type": ["string", "null"]},
        "dedupe_key": {"type": "string"}
      }
    },
    "payload_classification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["data_classification", "redistribution", "contains_private_source_content"],
      "properties": {
        "data_classification": {
          "type": "string",
          "enum": ["private", "public", "sanitized_fixture"]
        },
        "redistribution": {
          "type": "string",
          "enum": ["do_not_export", "public_contract_only"]
        },
        "contains_private_source_content": {"type": "boolean"}
      }
    },
    "publicability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publication_class", "public_export_allowed", "reason_codes"],
      "properties": {
        "publication_class": {
          "type": "string",
          "enum": ["INTERNAL_ONLY", "UNKNOWN_REVIEW", "DERIVATIVE_PUBLIC_SAFE", "PUBLIC_SOURCE"]
        },
        "public_export_allowed": {"type": "boolean", "const": false},
        "reason_codes": {"type": "array", "items": {"type": "string"}}
      }
    },
    "quarantine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "reason_codes"],
      "properties": {
        "state": {"type": "string", "enum": ["quarantined", "released", "rejected"]},
        "reason_codes": {"type": "array", "items": {"type": "string"}}
      }
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ingest_run_id", "raw_payload_hash"],
      "properties": {
        "ingest_run_id": {"type": "string"},
        "raw_payload_hash": {"type": "string"}
      }
    }
  }
}
