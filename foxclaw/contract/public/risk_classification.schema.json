{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://easternpineventures.example/foxclaw/risk_classification.schema.json",
  "title": "FoxClaw Risk Classification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "schema_version",
    "risk_class",
    "meaning",
    "beginner_safe",
    "presentation",
    "requirements",
    "status"
  ],
  "properties": {
    "contract_version": {"type": "string", "const": "1.0.0"},
    "schema_version": {"type": "string", "const": "risk_classification.v1"},
    "risk_class": {
      "type": "string",
      "enum": ["RESEARCH", "WATCH", "STRUCTURED", "TACTICAL", "SPECULATIVE", "REDLINE", "REJECT"]
    },
    "meaning": {"type": "string"},
    "beginner_safe": {"type": "boolean"},
    "presentation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tone", "color_family"],
      "properties": {
        "tone": {"type": "string"},
        "color_family": {"type": "string"}
      }
    },
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "full_loss_acknowledgment",
        "clear_invalidation",
        "liquidity_warning",
        "leverage_warning",
        "event_risk_disclosure",
        "paper_rehearsal_encouraged",
        "one_click_copy_trade_allowed"
      ],
      "properties": {
        "full_loss_acknowledgment": {"type": "boolean"},
        "clear_invalidation": {"type": "boolean"},
        "liquidity_warning": {"type": "boolean"},
        "leverage_warning": {"type": "boolean"},
        "maximum_holding_condition": {"type": "boolean"},
        "event_risk_disclosure": {"type": "boolean"},
        "paper_rehearsal_encouraged": {"type": "boolean"},
        "one_click_copy_trade_allowed": {"type": "boolean", "const": false}
      }
    },
    "status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authority", "live_execution_allowed", "not_individualized_advice"],
      "properties": {
        "authority": {"type": "string", "enum": ["paper_only"]},
        "live_execution_allowed": {"type": "boolean", "const": false},
        "not_individualized_advice": {"type": "boolean", "const": true}
      }
    }
  }
}
